# URL pública del proyecto Supabase (cliente y server)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima de Supabase para uso desde el cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service role de Supabase. SOLO server-side, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# API key de Resend para envío de emails transaccionales
RESEND_API_KEY=

# Remitente verificado en Resend (ej: "Jose Blog <noreply@dominio.com>")
RESEND_FROM=

# Número de WhatsApp de contacto, con código país sin "+" (ej: 5491155512345)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL pública del sitio en producción (ej: https://www.dominio.com)
NEXT_PUBLIC_SITE_URL=
